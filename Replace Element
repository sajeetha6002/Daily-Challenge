class Solution {
    public int[] replaceElements(int[] arr) {
        int n=arr.length;
        int num[]=new int[n];
        for(int i=0;i<n-1;i++){
            int a=arr[i+1];
            for(int j=i+1;j<n;j++){
                if(arr[j]>a){
                    a=arr[j];
                }
            num[i]=a;
            }
        }
        num[n-1]=-1;
        return num;
    }
}
