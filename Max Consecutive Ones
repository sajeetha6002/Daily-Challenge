class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        if(nums.length==1){
            return nums[0];
        }
        int count=0;
        int a=1;
        int max=0;
        for(int i=0;i<nums.length;i++){
            if(a==nums[i]){
                count++;
            }
            else{
                count=0;
            }
            if(count>max){
                max=count;
            }
        }
        return max;
    }
}
